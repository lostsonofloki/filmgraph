# TMDB API Key
# Get your free API key at: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Supabase (client + optional server-side cache helpers)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Optional for server-side cache writes in Vercel functions:
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# UPC cache freshness window in hours (default: 336 = 14 days)
UPC_CACHE_TTL_HOURS=336

# Gemini API Key (Phase 5: AI Integration)
# Get your free API key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Phase 6.15: High-Speed AI Ensemble)
# Get your free API key at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (Emergency Fallback)
# Get your key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# NYT Top Stories API Key (Editorial Enrichment)
# Get your key at: https://developer.nytimes.com/
VITE_NYT_API_KEY=your_nyt_api_key_here

# Fanart.tv API Key (Visual Enrichment)
# Get your key at: https://fanart.tv/get-an-api-key/
VITE_FANART_API_KEY=your_fanart_api_key_here

# Trakt OAuth App Credentials (Tracking Sync)
# Create app at: https://trakt.tv/oauth/applications
VITE_TRAKT_CLIENT_ID=your_trakt_client_id_here
VITE_TRAKT_CLIENT_SECRET=your_trakt_client_secret_here

# Resend Bug Report Notifications (Server-side only, no VITE_ prefix)
# Get your key at: https://resend.com/api-keys
# Add these in Vercel Project Settings -> Environment Variables
RESEND_API_KEY=your_resend_api_key_here
BUG_REPORT_FROM_EMAIL=alerts@filmgraph.app
BUG_REPORT_ADMIN_EMAIL=your_admin_inbox@example.com

# Optional API Enrichment Feature Flags
# Set to true to enable each enrichment family.
VITE_FEATURE_EDITORIAL_ENRICHMENT=false
VITE_FEATURE_VISUAL_ENRICHMENT=false
VITE_FEATURE_TRAKT_ENRICHMENT=false

# Playwright Test Credentials
# Used for automated portfolio screenshots
TEST_USER_EMAIL=your_email@example.com
TEST_USER_PASSWORD=your_password
